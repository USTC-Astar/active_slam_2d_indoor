Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Map1
        - /Global Costmap1
        - /Local Costmap1
        - /Frontiers1
        - /Submaps1
        - /Scan1
        - /Robot View1
      Splitter Ratio: 0.6
    Tree Height: 650
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.45
      Cell Size: 1
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 80
      Reference Frame: <Fixed Frame>
      Value: true
    - Class: rviz/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: true
      Marker Scale: 0.35
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: false
      Tree:
        map:
          odom:
            base_link:
              base_footprint:
                {}
              camera_link:
                {}
              laser_link:
                {}
      Update Interval: 0
      Value: true
    - Alpha: 1
      Class: rviz/RobotModel
      Collision Enabled: false
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
      Name: RobotModel
      Robot Description: robot_description
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    - Alpha: 1
      Class: rviz/Map
      Color Scheme: map
      Draw Behind: false
      Enabled: true
      Name: Map
      Topic: /map
      Unreliable: false
      Use Timestamp: false
      Value: true
    - Alpha: 0.18
      Class: rviz/Map
      Color Scheme: costmap
      Draw Behind: false
      Enabled: true
      Name: Navigation Costmap
      Topic: /active_slam/costmap
      Unreliable: false
      Use Timestamp: false
      Value: true
    - Alpha: 0.32
      Class: rviz/Map
      Color Scheme: costmap
      Draw Behind: false
      Enabled: false
      Name: Legacy Local Costmap
      Topic: /move_base/local_costmap/costmap
      Unreliable: false
      Use Timestamp: false
      Value: false
    - Class: Submaps
      Enabled: false
      Name: Cartographer Submaps
      Submap query service: /submap_query
      Topic: /submap_list
      Tracking frame: base_link
      Unreliable: false
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /trajectory_node_list
      Name: Cartographer Trajectory
      Namespaces: {}
      Queue Size: 10
      Value: false
    - Class: rviz/MarkerArray
      Enabled: false
      Marker Topic: /constraint_list
      Name: Cartographer Constraints
      Namespaces: {}
      Queue Size: 10
      Value: false
    - Class: rviz/LaserScan
      Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 10
        Min Value: -10
        Value: true
      Axis: Z
      Channel Name: intensity
      Color: 55; 220; 255
      Color Transformer: FlatColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Min Color: 0; 0; 0
      Name: Scan
      Position Transformer: XYZ
      Queue Size: 10
      Selectable: true
      Size (Pixels): 2
      Size (m): 0.025
      Style: Flat Squares
      Topic: /scan
      Unreliable: false
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    - Class: rviz/Path
      Alpha: 0.75
      Buffer Length: 1
      Color: 42; 180; 162
      Enabled: false
      Head Diameter: 0.2
      Head Length: 0.3
      Length: 0.3
      Line Style: Lines
      Line Width: 0.06
      Name: Autonomous Waypoints
      Offset:
        X: 0
        Y: 0
        Z: 0.03
      Pose Color: 255; 85; 0
      Pose Style: Axes
      Radius: 0.03
      Shaft Diameter: 0.1
      Shaft Length: 0.2
      Topic: /indoor_mapper/waypoints
      Unreliable: false
      Value: false
    - Class: rviz/MarkerArray
      Enabled: true
      Marker Topic: /active_slam/frontiers
      Name: Active SLAM Frontiers
      Namespaces:
        frontiers: true
      Queue Size: 100
      Value: true
    - Class: rviz/Path
      Alpha: 0.95
      Buffer Length: 1
      Color: 30; 210; 90
      Enabled: true
      Head Diameter: 0.2
      Head Length: 0.3
      Length: 0.3
      Line Style: Lines
      Line Width: 0.045
      Name: Active SLAM Path
      Offset:
        X: 0
        Y: 0
        Z: 0.05
      Pose Color: 30; 210; 90
      Pose Style: None
      Radius: 0.03
      Shaft Diameter: 0.1
      Shaft Length: 0.2
      Topic: /active_slam/path
      Unreliable: false
      Value: true
    - Class: rviz/Path
      Alpha: 0.95
      Buffer Length: 1
      Color: 255; 185; 40
      Enabled: false
      Head Diameter: 0.2
      Head Length: 0.3
      Length: 0.3
      Line Style: Lines
      Line Width: 0.04
      Name: Local Plan
      Offset:
        X: 0
        Y: 0
        Z: 0.07
      Pose Color: 255; 170; 0
      Pose Style: None
      Radius: 0.03
      Shaft Diameter: 0.1
      Shaft Length: 0.2
      Topic: /move_base/DWAPlannerROS/local_plan
      Unreliable: false
      Value: false
    - Class: rviz/Pose
      Alpha: 1
      Axes Length: 0.5
      Axes Radius: 0.05
      Color: 255; 80; 40
      Enabled: true
      Head Length: 0.3
      Head Radius: 0.1
      Name: Current Target
      Shaft Length: 0.8
      Shaft Radius: 0.05
      Shape: Arrow
      Topic: /active_slam/target
      Unreliable: false
      Value: true
    - Class: rviz/Image
      Enabled: true
      Image Topic: /robot_view/image_raw
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Robot View
      Normalize Range: true
      Queue Size: 2
      Transport Hint: raw
      Unreliable: false
      Value: true
  Enabled: true
  Global Options:
    Background Color: 70; 72; 74
    Fixed Frame: map
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Topic: /initialpose
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Angle: 0
      Class: rviz/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Name: Current View
      Near Clip Distance: 0.01
      Scale: 13
      Target Frame: <Fixed Frame>
      Value: TopDownOrtho (rviz)
      X: 0
      Y: 0
    Saved: ~
Window Geometry:
  Displays:
    collapsed: true
  Height: 1080
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 000000ff00000000fd0000000100000000000001180000044cfc0200000002fb000000100044006900730070006c00610079007301000000000000032f0000002c00fffffffb000000140052006f0062006f0074002000560069006500770100000335000001170000002c00ffffff000006e40000044c00000004000000040000000800000008fc00000000
  Robot View:
    collapsed: false
  Width: 1800
  X: 50
  Y: 50
