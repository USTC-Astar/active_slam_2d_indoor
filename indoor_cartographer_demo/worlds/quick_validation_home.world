<?xml version="1.0"?>
<sdf version="1.6">
  <world name="quick_validation_home">
    <include><uri>model://sun</uri></include>

    <physics name="ode_physics" default="1" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <scene>
      <ambient>0.72 0.72 0.72 1</ambient>
      <background>0.82 0.88 0.93 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="home_fill" type="point">
      <pose>0 0 3.0 0 0 0</pose>
      <diffuse>1.0 0.94 0.84 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation><range>14</range><constant>0.55</constant><linear>0.02</linear><quadratic>0.006</quadratic></attenuation>
    </light>

    <model name="quick_home">
      <static>true</static>

      <link name="floor">
        <pose>0 0 0 0 0 0</pose>
        <collision name="collision"><geometry><box><size>12 9 0.04</size></box></geometry></collision>
        <visual name="visual"><geometry><box><size>12 9 0.04</size></box></geometry><material><ambient>0.72 0.67 0.58 1</ambient><diffuse>0.84 0.79 0.69 1</diffuse></material></visual>
      </link>

      <!-- Outer shell. -->
      <link name="wall_n"><pose>0 4.5 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>12.2 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>12.2 0.14 2.5</size></box></geometry><material><ambient>0.84 0.83 0.78 1</ambient><diffuse>0.94 0.93 0.88 1</diffuse></material></visual></link>
      <link name="wall_s"><pose>0 -4.5 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>12.2 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>12.2 0.14 2.5</size></box></geometry><material><ambient>0.84 0.83 0.78 1</ambient><diffuse>0.94 0.93 0.88 1</diffuse></material></visual></link>
      <link name="wall_w"><pose>-6 0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 9.2 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 9.2 2.5</size></box></geometry><material><ambient>0.84 0.83 0.78 1</ambient><diffuse>0.94 0.93 0.88 1</diffuse></material></visual></link>
      <link name="wall_e"><pose>6 0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 9.2 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 9.2 2.5</size></box></geometry><material><ambient>0.84 0.83 0.78 1</ambient><diffuse>0.94 0.93 0.88 1</diffuse></material></visual></link>

      <!-- Wide 1.2 m door openings into both bedrooms and the bathroom. -->
      <link name="north_split_1"><pose>-5.0 1.0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>2.0 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.0 0.14 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="north_split_2"><pose>-1.55 1.0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>2.5 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.5 0.14 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="north_split_3"><pose>2.1 1.0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>2.4 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.4 0.14 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="north_split_4"><pose>5.25 1.0 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>1.5 0.14 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.5 0.14 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="bedroom_split"><pose>-1.5 2.75 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 3.5 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 3.5 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="bath_split"><pose>2.5 2.75 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 3.5 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 3.5 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>

      <!-- Kitchen divider with a wide doorway. -->
      <link name="kitchen_split_s"><pose>1.8 -3.25 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 2.5 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 2.5 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>
      <link name="kitchen_split_n"><pose>1.8 0.1 1.25 0 0 0</pose><collision name="collision"><geometry><box><size>0.14 1.8 2.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.14 1.8 2.5</size></box></geometry><material><ambient>0.80 0.82 0.82 1</ambient><diffuse>0.90 0.92 0.92 1</diffuse></material></visual></link>

      <!-- Sparse furniture leaves broad routes for quick algorithm checks. -->
      <link name="bed_one"><pose>-4.7 3.35 0.28 0 0 0</pose><collision name="collision"><geometry><box><size>1.5 1.9 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.5 1.9 0.5</size></box></geometry><material><ambient>0.38 0.48 0.62 1</ambient><diffuse>0.48 0.60 0.76 1</diffuse></material></visual></link>
      <link name="bed_two"><pose>0.5 3.35 0.28 0 0 0</pose><collision name="collision"><geometry><box><size>1.5 1.9 0.5</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.5 1.9 0.5</size></box></geometry><material><ambient>0.55 0.42 0.46 1</ambient><diffuse>0.68 0.52 0.58 1</diffuse></material></visual></link>
      <link name="sofa"><pose>-4.7 -0.5 0.36 0 0 1.5708</pose><collision name="collision"><geometry><box><size>2.1 0.75 0.7</size></box></geometry></collision><visual name="visual"><geometry><box><size>2.1 0.75 0.7</size></box></geometry><material><ambient>0.20 0.34 0.36 1</ambient><diffuse>0.28 0.46 0.49 1</diffuse></material></visual></link>
      <link name="coffee_table"><pose>-2.7 -1.0 0.24 0 0 0</pose><collision name="collision"><geometry><box><size>1.1 0.65 0.42</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.1 0.65 0.42</size></box></geometry><material><ambient>0.45 0.27 0.13 1</ambient><diffuse>0.60 0.37 0.18 1</diffuse></material></visual></link>
      <link name="kitchen_counter"><pose>5.45 -2.2 0.45 0 0 0</pose><collision name="collision"><geometry><box><size>0.75 3.7 0.9</size></box></geometry></collision><visual name="visual"><geometry><box><size>0.75 3.7 0.9</size></box></geometry><material><ambient>0.50 0.50 0.47 1</ambient><diffuse>0.64 0.64 0.60 1</diffuse></material></visual></link>
      <link name="kitchen_island"><pose>3.65 -2.5 0.45 0 0 0</pose><collision name="collision"><geometry><box><size>1.25 0.65 0.9</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.25 0.65 0.9</size></box></geometry><material><ambient>0.32 0.37 0.38 1</ambient><diffuse>0.44 0.50 0.51 1</diffuse></material></visual></link>
      <link name="bathtub"><pose>4.85 3.55 0.32 0 0 0</pose><collision name="collision"><geometry><box><size>1.7 0.75 0.58</size></box></geometry></collision><visual name="visual"><geometry><box><size>1.7 0.75 0.58</size></box></geometry><material><ambient>0.82 0.86 0.87 1</ambient><diffuse>0.96 0.99 1.0 1</diffuse></material></visual></link>
      <link name="toilet"><pose>3.25 2.0 0.30 0 0 0</pose><collision name="collision"><geometry><cylinder><radius>0.3</radius><length>0.55</length></cylinder></geometry></collision><visual name="visual"><geometry><cylinder><radius>0.3</radius><length>0.55</length></cylinder></geometry><material><ambient>0.88 0.90 0.90 1</ambient><diffuse>0.99 1.0 1.0 1</diffuse></material></visual></link>
    </model>
  </world>
</sdf>
